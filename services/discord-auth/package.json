{
  "name": "nullscape-discord-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bundle": "node scripts/build-source-bundle.mjs",
    "dev": "wrangler dev",
    "deploy": "npm run bundle && wrangler deploy",
    "db:local": "wrangler d1 migrations apply NULLSCAPE_AUTH --local",
    "db:remote": "wrangler d1 migrations apply NULLSCAPE_AUTH --remote",
    "check": "npm run bundle && node --test test/*.test.js && wrangler deploy --dry-run --outdir dist"
  },
  "devDependencies": {
    "wrangler": "4.112.0"
  }
}
